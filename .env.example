# Slack App credentials — from api.slack.com/apps
SLACK_BOT_TOKEN=           # xoxb-... OAuth bot token from OAuth & Permissions page
SLACK_SIGNING_SECRET=      # From App Basic Information page, used to verify request signatures

# Anthropic API — from console.anthropic.com
ANTHROPIC_API_KEY=         # sk-ant-... Anthropic API key

# Airtable — from airtable.com/create/tokens
AIRTABLE_API_KEY=          # Personal Access Token (pat...) with data.records:read/write and schema.bases:read
AIRTABLE_BASE_ID=          # Base ID starting with "app" — visible in the base URL

# Slack channel where the morning digest is posted
DIGEST_CHANNEL_ID=         # Slack channel ID (e.g. C0XXXXXXXX) — right-click channel → Copy link → extract ID

# Your deployed Netlify site URL — used for fire-and-forget to background function
NETLIFY_SITE_URL=          # e.g. https://your-site-name.netlify.app
